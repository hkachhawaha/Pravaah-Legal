---
import BaseLayout from "@layouts/BaseLayout.astro";
import Navbar from "@components/Navbar.astro";
import Footer from "@components/Footer.astro";
import CTA from "@components/CTA.astro";

const values = [
  {
    title: "Professionalism",
    description: "Providing high-fidelity case prep, contract structures, and systematic legal consultations for scaling teams.",
    icon: "fa-solid fa-graduation-cap"
  },
  {
    title: "Integrity",
    description: "Maintaining strict compliance matrices, secure document repository protocols, and clear transparency metrics.",
    icon: "fa-solid fa-scale-balanced"
  },
  {
    title: "Efficiency",
    description: "Accelerating case assembly speeds, workflow reviews, and response timelines using structured LPO paradigms.",
    icon: "fa-solid fa-bolt-lightning"
  }
];
---

<BaseLayout title="About Pravaah Legal | Immigration & Corporate Advisors" description="Read our corporate story, organizational values (Professionalism, Integrity, Efficiency), leadership grids, and timeline.">

    <Navbar />

    <main>

        <section class="about-hero">

            <div class="container text-center">

                <span class="about-hero__eyebrow">COMPANY STORY</span>

                <h1>Navigating Legal Complexity</h1>

                <p class="about-hero__subtitle">

                    Pravaah Legal helps global organizations, law firms, and growth companies streamline legal operations.

                </p>

            </div>

        </section>

        <section class="about-story">

            <div class="container about-story__grid">

                <div class="about-story__content">

                    <h2>Who We Are</h2>

                    <p>

                        Pravaah Legal was founded with a clear objective: to bridge the gap between traditional corporate legal complexity and modern business velocity. Headquartered in Jaipur, Rajasthan, we provide premium legal consulting solutions spanning corporate advisory, contract structures, and global business immigration parameters.

                    </p>

                    <p>

                        As legal outsourcing workflows grow in importance, our structured paralegal case processing services give international law firms and scale organizations the operational leverage required to scale while managing overhead costs.

                    </p>

                </div>

                <div class="about-story__visual glass rounded">

                    <div class="visual-badge">

                        <h3>15+</h3>

                        <p>Years Collective Experience</p>

                    </div>

                </div>

            </div>

        </section>

        <section class="values">

            <div class="container">

                <h2 class="text-center values__title">Our Core Values</h2>

                <div class="values__grid">

                    {
                        values.map(val => (

                            <div class="value-card glass hover-lift">

                                <div class="value-card__icon">

                                    <i class={val.icon}></i>

                                </div>

                                <h3>

                                    {val.title}

                                </h3>

                                <p>

                                    {val.description}

                                </p>

                            </div>

                        ))
                    }

                </div>

            </div>

        </section>

        <CTA />

    </main>

    <Footer />

</BaseLayout>

<style lang="scss">

.about-hero{

    padding-top:140px;

    padding-bottom:4rem;

}

.about-hero__eyebrow{

    color:var(--gold);

    letter-spacing:.25em;

    text-transform:uppercase;

    font-size:.85rem;

}

.about-hero h1{

    margin:1rem 0;

}

.about-hero__subtitle{

    color:var(--muted);

    font-size:1.15rem;

    max-width:680px;

    margin:auto;

}

.about-story{

    background:var(--surface);

    border-top:1px solid rgba(255,255,255,.04);

}

.about-story__grid{

    display:grid;

    grid-template-columns:1fr 1fr;

    gap:5rem;

    align-items:center;

}

.about-story__content h2{

    font-size:2.4rem;

    margin-bottom:1.5rem;

}

.about-story__content p{

    color:var(--muted);

    font-size:1.05rem;

    line-height:1.7;

    margin-bottom:1.5rem;

}

.about-story__visual{

    height:380px;

    display:flex;

    align-items:center;

    justify-content:center;

    background-image:linear-gradient(135deg, rgba(176,141,87,.08), rgba(255,255,255,.02));

    border:1px solid var(--border);

    text-align:center;

}

.visual-badge h3{

    font-size:4rem;

    color:var(--gold);

    font-weight:800;

    margin-bottom:.5rem;

}

.visual-badge p{

    font-size:1.1rem;

    color:white;

    font-weight:600;

}

.values{

    background:var(--background);

    padding:8rem 0;

}

.values__title{

    margin-bottom:5rem;

}

.values__grid{

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:2.5rem;

}

.value-card{

    padding:3.5rem 2.5rem;

    border:1px solid var(--border);

    border-radius:var(--radius);

}

.value-card:hover{

    border-color:var(--gold);

}

.value-card__icon{

    background:rgba(176,141,87,.08);

    width:56px;

    height:56px;

    border-radius:12px;

    display:flex;

    align-items:center;

    justify-content:center;

    margin-bottom:2rem;

}

.value-card__icon i{

    color:var(--gold);

    font-size:1.5rem;

}

.value-card h3{

    font-size:1.4rem;

    margin-bottom:1rem;

}

.value-card p{

    color:var(--muted);

    font-size:.95rem;

    line-height:1.6;

}

@media(max-width:992px){

.about-story__grid{

grid-template-columns:1fr;

gap:3rem;

}

.values__grid{

grid-template-columns:1fr;

}

}

</style>
