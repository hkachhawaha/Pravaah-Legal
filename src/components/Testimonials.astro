---
const testimonials = [
  {
    quote: "Pravaah Legal revamped our entire business immigration process. Their case management team handled our H-1B filings flawlessly.",
    author: "CEO, Tech Enterprise",
    company: "SaaS Solutions Inc.",
    rating: 5
  },
  {
    quote: "Their LPO document review models saved our law firm countless hours of manual overhead. An invaluable partner for legal scaling.",
    author: "Senior Managing Partner",
    company: "Apex Law Group",
    rating: 5
  },
  {
    quote: "Excellent contract drafting and risk compliance advising. They helped us restructure our global vendor agreements with confidence.",
    author: "VP of Legal Operations",
    company: "Global Logistics Ltd.",
    rating: 5
  }
];
---

<section class="testimonials">

    <div class="container">

        <div class="testimonials__header text-center">

            <span class="testimonials__eyebrow">

                CLIENT REVIEWS

            </span>

            <h2>

                What Our Partners Say

            </h2>

            <p class="testimonials__subtitle">

                Read verified feedback from corporate organizations, law firms, and tech startups scaling with our advisory services.

            </p>

        </div>

        <div class="testimonials__slider swiper">

            <div class="swiper-wrapper">

                {
                    testimonials.map(item => (

                        <div class="swiper-slide testimonial-card glass">

                            <div class="testimonial-card__rating">

                                {
                                    Array.from({ length: item.rating }).map(() => (

                                        <span class="star">★</span>

                                    ))
                                }

                            </div>

                            <p class="testimonial-card__quote">

                                "{item.quote}"

                            </p>

                            <div class="testimonial-card__author">

                                <h4>

                                    {item.author}

                                </h4>

                                <span>

                                    {item.company}

                                </span>

                            </div>

                        </div>

                    ))
                }

            </div>

            <div class="swiper-pagination"></div>

            <div class="swiper-button-prev"></div>

            <div class="swiper-button-next"></div>

        </div>

    </div>

</section>

<!-- Import Swiper CSS locally in component styles, and Swiper JS via client side script -->

<script>
import Swiper from 'swiper';
import { Navigation, Pagination, Autoplay } from 'swiper/modules';
import 'swiper/css';
import 'swiper/css/navigation';
import 'swiper/css/pagination';

new Swiper('.testimonials__slider', {
  modules: [Navigation, Pagination, Autoplay],
  slidesPerView: 1,
  spaceBetween: 30,
  loop: true,
  autoplay: {
    delay: 5000,
    disableOnInteraction: false,
  },
  pagination: {
    el: '.swiper-pagination',
    clickable: true,
  },
  navigation: {
    nextEl: '.swiper-button-next',
    prevEl: '.swiper-button-prev',
  },
  breakpoints: {
    768: {
      slidesPerView: 2,
    },
    1024: {
      slidesPerView: 2,
      spaceBetween: 40,
    }
  }
});
</script>

<style lang="scss">

.testimonials{

    background:var(--surface);

    border-top:1px solid rgba(255,255,255,.04);

}

.testimonials__header{

    margin-bottom:5rem;

}

.testimonials__eyebrow{

    color:var(--gold);

    letter-spacing:.2em;

    text-transform:uppercase;

    font-size:.85rem;

}

.testimonials__header h2{

    margin:1rem auto;

    max-width:600px;

}

.testimonials__subtitle{

    max-width:680px;

    margin:auto;

    color:var(--muted);

}

.testimonials__slider{

    padding:2rem 1rem 4rem !important;

}

.testimonial-card{

    padding:3rem;

    border-radius:var(--radius);

    display:flex;

    flex-direction:column;

    gap:2rem;

    height:auto;

}

.testimonial-card__rating{

    color:var(--gold);

    font-size:1.2rem;

    letter-spacing:4px;

}

.testimonial-card__quote{

    font-size:1.15rem;

    line-height:1.7;

    color:var(--text);

    flex-grow:1;

}

.testimonial-card__author h4{

    font-size:1.1rem;

    margin-bottom:.3rem;

}

.testimonial-card__author span{

    color:var(--muted);

    font-size:.9rem;

}

/* Custom Swiper Controls Styling */

:global(.swiper-pagination-bullet){

    background:rgba(255,255,255,.2) !important;

    opacity:1 !important;

}

:global(.swiper-pagination-bullet-active){

    background:var(--gold) !important;

}

:global(.swiper-button-next),

:global(.swiper-button-prev){

    color:var(--gold) !important;

    transform:scale(.7);

}

:global(.swiper-button-next::after),

:global(.swiper-button-prev::after){

    font-size:2rem !important;

}

</style>
